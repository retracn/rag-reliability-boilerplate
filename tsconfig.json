{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["index.ts", "mcp-server.ts", "langchain-tool.ts"]
}
