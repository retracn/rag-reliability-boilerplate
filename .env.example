# Apify account token — required, powers sync()/synthesize()/deliver() via the Delta-Sync actors.
APIFY_TOKEN=

# Your own Anthropic key (BYOK) — required for synthesize()/run() with LLM extraction.
ANTHROPIC_API_KEY=

# Shared secret used to HMAC-sign and verify webhook deliveries. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# Publicly reachable base URL for THIS server (e.g. an ngrok URL in dev, your real domain in prod).
# The Orchestrator actor calls out to `${PUBLIC_URL}/webhooks/foundry` — localhost will not work
# unless it's tunneled.
PUBLIC_URL=http://localhost:3000

PORT=3000
